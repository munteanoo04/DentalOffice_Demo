@page "/login"
@inject AuthService AuthSvc
@inject NavigationManager Nav
@rendermode InteractiveServer

<h3>Dental Clinic Login</h3>

@if (_error)
{
    <p style="color:red">Invalid email or password.</p>
}

<input type="email" @bind="_email"
       placeholder="Email" style="display:block; margin-bottom:8px;" />
<input type="password" @bind="_password"
       placeholder="Password" style="display:block; margin-bottom:8px;" />
<button @onclick="HandleLogin">Login</button>

@code {
    string _email = string.Empty;
    string _password = string.Empty;
    bool _error = false;

    async Task HandleLogin()
    {
        _error = false;
        var ok = await AuthSvc.LoginAsync(_email, _password);
        if (ok) Nav.NavigateTo("/patients");
        else _error = true;
    }
}