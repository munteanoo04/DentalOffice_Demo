@page "/patients"
@using DentalClinic.Web.Models
@inject PatientService PatientSvc
@inject AuthService AuthSvc
@inject NavigationManager Nav
@rendermode InteractiveServer

<h3 class="mb-4">👤 Patients</h3>

@if (!AuthSvc.IsLoggedIn)
{
    <div class="alert alert-warning">
        Please <a href="/login">login</a> first.
    </div>
}
else
{
    <button class="btn btn-primary mb-3" @onclick="ToggleForm">
        + Add Patient
    </button>

    @if (_showForm)
    {
        <div class="card mb-4">
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <input class="form-control" placeholder="First name"
                               @bind="_req.FirstName" />
                    </div>
                    <div class="col-md-6">
                        <input class="form-control" placeholder="Last name"
                               @bind="_req.LastName" />
                    </div>
                    <div class="col-md-6">
                        <input class="form-control" placeholder="Email"
                               @bind="_req.Email" />
                    </div>
                    <div class="col-md-6">
                        <input class="form-control" placeholder="Phone"
                               @bind="_req.PhoneNumber" />
                    </div>
                    <div class="col-md-6">
                        <input type="date" class="form-control"
                               @bind-value="_req.DateOfBirth"
                               @bind-value:event="onchange" />
                    </div>
                    <div class="col-12">
                        <button class="btn btn-success" @onclick="HandleCreate">
                            Save
                        </button>
                        <button class="btn btn-secondary ms-2" @onclick="CloseForm">
                            Cancel
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (_patients == null)
    {
        <div class="spinner-border text-primary"></div>
    }
    else if (!_patients.Any())
    {
        <div class="alert alert-info">No patients found.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover table-striped">
                <thead class="table-primary">
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Age</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in _patients)
                    {
                        <tr>
                            <td>@p.FirstName @p.LastName</td>
                            <td>@p.Email</td>
                            <td>@p.PhoneNumber</td>
                            <td>@p.Age</td>
                            <td>
                                <button class="btn btn-danger btn-sm"
                                        @onclick="() => HandleDelete(p.Id)">
                                    Delete
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@code {
    List<PatientDto>? _patients;
    bool _showForm;
    CreatePatientRequest _req = new();

    protected override async Task OnInitializedAsync()
    {
        if (!AuthSvc.IsLoggedIn)
        {
            try { Nav.NavigateTo("/login", forceLoad: false); } catch { }
            return;
        }

        await LoadPatients();
    }

    async Task LoadPatients()
    {
        _patients = await PatientSvc.GetAllAsync();
    }

    async Task HandleCreate()
    {
        var ok = await PatientSvc.CreateAsync(_req);
        if (ok)
        {
            _showForm = false;
            _req = new();
            await LoadPatients();
        }
    }

    async Task HandleDelete(int id)
    {
        await PatientSvc.DeleteAsync(id);
        await LoadPatients();
    }

    void ToggleForm() => _showForm = !_showForm;
    void CloseForm() => _showForm = false;
}