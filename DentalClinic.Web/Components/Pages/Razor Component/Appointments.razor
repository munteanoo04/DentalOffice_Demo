@page "/appointments"
@inject AppointmentService AppointmentSvc
@inject AuthService AuthSvc
@rendermode InteractiveServer
@inject NavigationManager Nav

<h3 class="mb-4">📅 Appointments</h3>

@if (!AuthSvc.IsLoggedIn)
{
    <div class="alert alert-warning">
        Please <a href="/login">login</a> first.
    </div>
}
else
{
    <div class="input-group mb-4" style="max-width:400px;">
        <input type="number" class="form-control"
               placeholder="Enter Patient ID"
               @bind="_patientId" />
        <button class="btn btn-primary"
                @onclick="LoadAppointments">
            Search
        </button>
    </div>

    @if (_appointments is null)
    {
        <div class="alert alert-secondary">
            Enter a patient ID to search appointments.
        </div>
    }
    else if (!_appointments.Any())
    {
        <div class="alert alert-info">No appointments found.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover table-striped">
                <thead class="table-primary">
                    <tr>
                        <th>Date</th>
                        <th>Doctor</th>
                        <th>Procedure</th>
                        <th>Treatment</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var a in _appointments)
                    {
                        <tr>
                            <td>@a.ScheduledAt.ToString("dd MMM yyyy HH:mm")</td>
                            <td>@a.DoctorName</td>
                            <td>@a.ProcedureName</td>
                            <td>@a.TreatmentType</td>
                            <td>
                                <span class="badge @GetStatusBadge(a.Status)">
                                    @a.Status
                                </span>
                            </td>
                            <td>
                                @if (a.Status == "Scheduled")
                                {
                                    <button class="btn btn-warning btn-sm"
                                            @onclick="() => HandleCancel(a.Id)">
                                        Cancel
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@code {
    int _patientId = 0;
    List<AppointmentDto>? _appointments = null;

    async Task LoadAppointments()
        => _appointments = await AppointmentSvc.GetByPatientAsync(_patientId);

    async Task HandleCancel(int id)
    {
        await AppointmentSvc.CancelAsync(id);
        await LoadAppointments();
    }
    protected override async Task OnInitializedAsync()
    {
        if (!AuthSvc.IsLoggedIn)
        {
            try { Nav.NavigateTo("/login", forceLoad: false); } catch { }
            return;
        }
        await LoadAppointments();

    }

    string GetStatusBadge(string status) => status switch
    {
        "Scheduled" => "bg-primary",
        "Completed" => "bg-success",
        "Cancelled" => "bg-danger",
        "InProgress" => "bg-warning text-dark",
        "NoShow" => "bg-secondary",
        _ => "bg-light text-dark"
    };
}    


    
        