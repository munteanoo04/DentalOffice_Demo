@page "/doctors"
@inject DoctorService DoctorSvc
@inject AuthService AuthSvc
@rendermode InteractiveServer
@inject NavigationManager Nav

<h3 class="mb-4">👨‍⚕️ Doctors</h3>

@if (!AuthSvc.IsLoggedIn)
{
    <div class="alert alert-warning">
        Please <a href="/login">login</a> first.
    </div>
}
else
{
    <button class="btn btn-primary mb-3"
            @onclick="() => _showForm = !_showForm">
        + Add Doctor
    </button>

    @if (_showForm)
    {
        <div class="card mb-4">
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <input class="form-control" placeholder="First name"
                               @bind="_req.FirstName" />
                    </div>
                    <div class="col-md-6">
                        <input class="form-control" placeholder="Last name"
                               @bind="_req.LastName" />
                    </div>
                    <div class="col-md-6">
                        <input class="form-control" placeholder="Email"
                               @bind="_req.Email" />
                    </div>
                    <div class="col-md-6">
                        <input class="form-control" placeholder="Phone"
                               @bind="_req.PhoneNumber" />
                    </div>
                    <div class="col-md-6">
                        <input class="form-control" placeholder="Specialization"
                               @bind="_req.Specialization" />
                    </div>
                    <div class="col-12">
                        <button class="btn btn-success"
                                @onclick="HandleCreate">
                            Save
                        </button>
                        <button class="btn btn-secondary ms-2"
                                @onclick="() => _showForm = false">
                            Cancel
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (_doctors is null)
    {
        <div class="spinner-border text-primary"></div>
    }
    else if (!_doctors.Any())
    {
        <div class="alert alert-info">No doctors found.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover table-striped">
                <thead class="table-primary">
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Specialization</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var d in _doctors)
                    {
                        <tr>
                            <td>@d.FirstName @d.LastName</td>
                            <td>@d.Email</td>
                            <td>@d.Specialization</td>
                            <td>
                                <button class="btn btn-danger btn-sm"
                                        @onclick="() => HandleDelete(d.Id)">
                                    Delete
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}

@code {
    List<DoctorDto>? _doctors = null;
    bool _showForm = false;
    CreateDoctorRequest _req = new();

    protected override async Task OnInitializedAsync()
    {
        if (AuthSvc.IsLoggedIn)
            _doctors = await DoctorSvc.GetAllAsync();
    }

    async Task HandleCreate()
    {
        var ok = await DoctorSvc.CreateAsync(_req);
        if (ok)
        {
            _showForm = false;
            _req = new();
            _doctors = await DoctorSvc.GetAllAsync();
        }
    }
   

    async Task HandleDelete(int id)
    {
        await DoctorSvc.DeleteAsync(id);
        _doctors = await DoctorSvc.GetAllAsync();
    }
}
